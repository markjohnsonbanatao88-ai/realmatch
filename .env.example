# Real Match environment template. Copy to .env.local and fill in.
# Placeholder-only: never commit real values.

# Canonical site URL (used for metadata, sitemap, robots).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Operational status gate: preview | pilot | live
# preview = marketing visible; no applications or payments processed.
# Do not set pilot/live until PRODUCTION_READINESS.md gates are met.
NEXT_PUBLIC_SERVICE_STATUS=preview

# --- Supabase ---
# The URL and publishable key can be exposed to browser code. The service role
# key is server-only and must never be named with a NEXT_PUBLIC_ prefix.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key

# Application fingerprints use HMAC so email and request hashes cannot be
# reproduced without this secret. Generate at least 32 random characters.
# APPLICATION_HASH_SECRET=

# --- PayPal (server-side only) ---
# Set PAYPAL_ENVIRONMENT to sandbox for testing and live only after Gate B.
# Rotate any credentials previously exposed outside protected secrets.
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_WEBHOOK_ID=
# PAYPAL_ENVIRONMENT=sandbox

# --- Operational safeguards (server-side only) ---
# The database intake migration provides a durable application limit. Keep an
# additional shared edge limit in production as defence in depth.
# TRUSTED_PROXY_HOPS=1
